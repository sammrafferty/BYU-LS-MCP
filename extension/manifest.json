{
  "manifest_version": 3,
  "name": "BYU Learning Suite → Claude",
  "version": "2.0.0",
  "description": "Automatically keeps your BYU Learning Suite connected to Claude. Zero maintenance.",
  "permissions": ["cookies", "tabs", "storage", "alarms"],
  "host_permissions": [
    "*://learningsuite.byu.edu/*",
    "http://localhost:3847/*",
    "https://*.up.railway.app/*",
    "https://*.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BYU LS → Claude"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
