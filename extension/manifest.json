{
  "manifest_version": 3,
  "name": "BYU Learning Suite → Claude",
  "version": "1.0.0",
  "description": "Connect your BYU Learning Suite to Claude with one click.",
  "permissions": ["cookies", "tabs", "storage"],
  "host_permissions": [
    "*://learningsuite.byu.edu/*",
    "http://localhost:3847/*",
    "https://*.up.railway.app/*",
    "https://*.railway.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Connect BYU LS to Claude"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
